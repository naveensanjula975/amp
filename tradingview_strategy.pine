//@version=5
strategy("Futures Automated Strategy MVP", overlay=true, margin_long=100, margin_short=100)

// --- Strategy Inputs ---
fastLength = input.int(10, title="Fast SMA Length")
slowLength = input.int(20, title="Slow SMA Length")
webhookSecret = input.string("your_super_secret_webhook_token_here", title="Webhook Secret")
tradeQuantity = input.int(1, title="Trade Quantity")
stopLossPoints = input.float(50.0, title="Stop Loss Points")
takeProfitPoints = input.float(150.0, title="Take Profit Points")

// --- Moving Averages ---
fastSMA = ta.sma(close, fastLength)
slowSMA = ta.sma(close, slowLength)

plot(fastSMA, color=color.blue, title="Fast SMA")
plot(slowSMA, color=color.red, title="Slow SMA")

// --- Trading Logic ---
longCondition = ta.crossover(fastSMA, slowSMA)
shortCondition = ta.crossunder(fastSMA, slowSMA)

// --- Alert Message Generator ---
// We use string.format to build the JSON payload as defined in the MVP schema.
generateAlertBody(actionStr) =>
    sl = actionStr == "buy" ? close - stopLossPoints : close + stopLossPoints
    tp = actionStr == "buy" ? close + takeProfitPoints : close - takeProfitPoints
    
    // Constructing the JSON string payload
    json = '{' +
      '"secret": "' + webhookSecret + '", ' +
      '"action": "' + actionStr + '", ' +
      '"symbol": "' + syminfo.ticker + '", ' +
      '"quantity": ' + str.tostring(tradeQuantity) + ', ' +
      '"order_type": "market", ' +
      '"price": null, ' +
      '"stop_loss": ' + str.tostring(sl) + ', ' +
      '"take_profit": ' + str.tostring(tp) + ', ' +
      '"strategy": "Futures Automated Strategy MVP", ' +
      '"timestamp": "' + str.format_time(time, "yyyy-MM-dd'T'HH:mm:ssZ", syminfo.timezone) + '"' +
      '}'
    json


// --- Order Execution & Alerts ---
if (longCondition)
    msg = generateAlertBody("buy")
    strategy.entry("Long", strategy.long, alert_message=msg)

if (shortCondition)
    msg = generateAlertBody("sell")
    strategy.entry("Short", strategy.short, alert_message=msg)

// --- Exit Logic ---
// We could also trigger 'close' alerts here if we manually manage exits via webhook,
// but for MVP, we rely on the stop loss / take profit orders placed via the API.
